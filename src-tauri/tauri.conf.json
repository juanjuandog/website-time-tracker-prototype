{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OrbitLog",
  "version": "0.1.0",
  "identifier": "app.orbitlog.desktop",
  "build": {
    "devUrl": "http://localhost:4174",
    "frontendDist": "../public"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "categoryPrompt",
        "title": "选择分类",
        "url": "/prompt.html",
        "width": 420,
        "height": 238,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "transparent": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../server.js", "../public"]
  }
}
